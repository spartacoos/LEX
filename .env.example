# Copy this file to .env and edit the values for your platform.
# .env is git-ignored; .env.example is the committed template.

# =====================================================================
# RAG LLM — the model used for answering questions.
# =====================================================================

LEX_LLM__BASE_URL=http://localhost:8080/v1

# Model name depends on your backend:
#   macOS MLX:     mlx-community/gemma-4-E4B-it-4bit
#   Linux llama.cpp: gemma-4-e4b-it
LEX_LLM__MODEL=mlx-community/gemma-4-E4B-it-4bit

LEX_LLM__MAX_TOKENS=2048
LEX_LLM__TEMPERATURE=0.1

# =====================================================================
# Services — defaults match docker-compose.yml.
# =====================================================================

LEX_QDRANT__URL=http://localhost:6333
LEX_REDIS__URL=redis://localhost:6379/0

# =====================================================================
# Eval judge — leave unset to use the RAG LLM for judging too.
# When running pytest -m eval, set these to point at a stronger model
# for better JSON compliance and scoring accuracy.
# =====================================================================

# LEX_EVAL_JUDGE__BASE_URL=http://localhost:8081/v1
# LEX_EVAL_JUDGE__MODEL=gemma-4-31b-it
# LEX_EVAL_JUDGE__API_KEY=sk-local

# Remote judge example (OpenAI):
# LEX_EVAL_JUDGE__BASE_URL=https://api.openai.com/v1
# LEX_EVAL_JUDGE__MODEL=gpt-4o-mini
# LEX_EVAL_JUDGE__API_KEY=sk-...

# =====================================================================
# Optional — Langfuse tracing. Leave unset to disable.
# =====================================================================

# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=http://localhost:3000
