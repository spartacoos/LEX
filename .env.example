# ============================================================
# LEX configuration template
# Copy to .env and run `lex config` to fill it in, OR
# set LEX_PROFILE and run `lex config --profile <name>`.
# ============================================================

# Active hardware/model profile.
# Run `lex config --list` to see available profiles.
# Run `lex config` for an interactive wizard.
#
# Profiles (in profiles/*.yaml):
#   gemma4-e2b-cpu    2B model, CPU-only, slowest, works everywhere
#   gemma4-e4b-gpu    4B model, GPU (CUDA/Metal), recommended default
#   gemma4-e4b-mlx    4B model, Apple Silicon MLX, best for macOS
#   gemma4-31b-gpu    31B model, needs 24+ GB VRAM, best quality
#   qwen35-9b-gpu     Qwen 3.5 9B, strong reasoning alternative
#   remote-openai     Remote API (OpenAI, Together, Groq, Anthropic, etc.)
LEX_PROFILE=gemma4-e4b-gpu

# ============================================================
# RAG LLM — the model used for answering questions
# ============================================================
LEX_LLM__BASE_URL=http://localhost:8080/v1

# Model name as seen by the OpenAI-compatible server:
#   llama.cpp:  gemma-4-e4b-it
#   mlx:        mlx-community/gemma-4-E4B-it-4bit
#   remote:     gpt-4o-mini / claude-3-5-haiku-latest / etc.
LEX_LLM__MODEL=gemma-4-e4b-it

LEX_LLM__MAX_TOKENS=2048
LEX_LLM__TEMPERATURE=0.1

# For remote APIs: set which env var holds your API key
# LEX_LLM__API_KEY_ENV=OPENAI_API_KEY
# LEX_LLM__API_KEY_ENV=ANTHROPIC_API_KEY

# LLM server launch parameters (used by `lex serve-llm`):
LEX_LLM__BACKEND=llamacpp        # llamacpp | mlx | remote
LEX_LLM__MODEL_FILE=gemma-4-E4B-it-Q4_K_M.gguf
LEX_LLM__HF_REPO=ggml-org/gemma-4-E4B-it-GGUF
LEX_LLM__PORT=8080
LEX_LLM__N_GPU_LAYERS=-1         # -1=all to GPU, 0=CPU only, 20=split
LEX_LLM__CTX_SIZE=32768

# ============================================================
# Embedder & Reranker
# ============================================================
# "auto" → cuda > mps > cpu.  Set explicitly on memory-constrained GPUs.
LEX_EMBEDDING__DEVICE=auto
LEX_RERANKER__DEVICE=cpu

# ============================================================
# Services — match docker-compose.yml defaults
# ============================================================
LEX_QDRANT__URL=http://localhost:6333
LEX_REDIS__URL=redis://localhost:6379/0

# ============================================================
# Eval judge — separate (usually larger) model for `pytest -m eval`
# Leave unset to reuse the RAG LLM above.
# ============================================================
# LEX_EVAL_JUDGE__BASE_URL=http://localhost:8081/v1
# LEX_EVAL_JUDGE__MODEL=gemma-4-31b-it
# LEX_EVAL_JUDGE__MAX_TOKENS=4096
# LEX_EVAL_JUDGE__TIMEOUT_S=3600.0

# Remote judge example:
# LEX_EVAL_JUDGE__BASE_URL=https://api.openai.com/v1
# LEX_EVAL_JUDGE__MODEL=gpt-4o-mini
# LEX_EVAL_JUDGE__API_KEY_ENV=OPENAI_API_KEY

# ============================================================
# Optional: Langfuse tracing (uncomment to enable)
# ============================================================
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=http://localhost:3000
